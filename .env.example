# -------------------------
# OpenAI
# -------------------------
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx


# -------------------------
# Redis (Celery broker)
# -------------------------
REDIS_URL=redis://localhost:6379/0


# -------------------------
# GitHub API
# increases rate limit
# -------------------------
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxx


# -------------------------
# n8n webhook callback
# -------------------------
N8N_WEBHOOK_URL=http://localhost:5678/webhook/scan-result

# optional auth token
N8N_TOKEN=securetoken123


# -------------------------
# FastAPI settings
# -------------------------
APP_ENV=development

LOG_LEVEL=INFO


# -------------------------
# Report storage
# -------------------------
REPORT_PATH=reports/


# -------------------------
# Celery settings
# -------------------------
CELERY_CONCURRENCY=2
CELERY_MAX_RETRIES=3