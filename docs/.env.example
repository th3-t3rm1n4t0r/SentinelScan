# =========================
# OPENAI
# =========================
OPENAI_API_KEY=your_openai_api_key_here

# =========================
# GITHUB
# =========================
GITHUB_TOKEN=your_github_token_here
GITHUB_API_BASE=https://api.github.com
GITHUB_DEFAULT_BRANCH=main

# ========================= 
# DATABASE (LOCAL)
# =========================
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/sentinelscan

# =========================
# REDIS / CELERY
# =========================
REDIS_URL=redis://localhost:6379/0
CELERY_CONCURRENCY=2

# =========================
# AI SETTINGS
# =========================
FAST_LLM_MODEL=gpt-4o-mini
AI_TIMEOUT=60
AI_RETRIES=3
AI_MAX_CHARS=120000

# =========================
# APP SETTINGS
# =========================
APP_NAME=SentinelScan
DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=*

# =========================
# SECURITY
# =========================
WEBHOOK_SECRET=change_me
ADMIN_SECRET=admin_secret_here

# =========================
# FILE LIMITS
# =========================
MAX_FILES=120
MAX_FILE_SIZE_KB=500

# =========================
# N8N WEBHOOK
# =========================
N8N_WEBHOOK_URL=http://localhost:5678/webhook/scan-result
WEBHOOK_TIMEOUT=20
WEBHOOK_RETRIES=3